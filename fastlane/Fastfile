platform :mac do

  private_lane :build_macos_package do |options|
    options[:sdk] = "macosx"
    options[:destination] = "generic/platform=macOS"
    # set signing the .app when building, because `xcodebuild` will not resign it when form .pkg.
    # `export_options` used only to sign .pkg to get `installerSigningCertificate`, `method` and `provisioningProfiles`.
    options[:skip_codesigning] = false
    build_app_package(options)
  end

  lane :build_dev do
    export_method = "development"
    profile_path = File.join(project_dir, "/.secrets/macOS-Development-#{bundle_id}.provisionprofile")
    install_certificate(
      signing_certificate: development_signing_certificate,
      export_method: export_method
    )
    install_provision_profile(
      profile_path: profile_path
    )
    build_macos_package(
      configuration: "Debug",
      export_method: export_method,
      export_options: generate_export_options(
        export_method: export_method,
        profile_path: profile_path
      )
    )
  end

  private_lane :build_distribution do
    export_method = "app-store"
    profile_path = File.join(project_dir, "/.secrets/macOS-Distribution-#{bundle_id}.provisionprofile")
    install_certificate(
      signing_certificate: distribution_signing_certificate,
      export_method: export_method
    )
    install_provision_profile(
      profile_path: profile_path
    )
    build_macos_package(
      export_method: export_method,
      export_options: generate_export_options(
        export_method: export_method,
        profile_path: profile_path
      )
    )
  end

  lane :make_testflight_release do
    pkg = build_distribution
    localized_app_info = localized_testflight_app_info
    upload_to_testflight(
      app_identifier: bundle_id,
      api_key: api_key,
      pkg: pkg,
      localized_app_info: localized_app_info,
      groups: ["Family"],
      submit_beta_review: false
    )
    upload_symbols(ipa: pkg, platform: "mac")
  end

  desc "Upload metadata to the Distribution page on App Store Connect"
  lane :upload_appstore_metadata do
    upload_appstore_meta(
      skip_screenshots: true,
      skip_metadata: false
    )
  end

  desc "Upload screenshots to the Distribution page on App Store Connect"
  lane :upload_appstore_screenshots do
    upload_appstore_meta(
      skip_screenshots: false,
      skip_metadata: true
    )
  end

  private_lane :upload_appstore_meta do |options|
    upload_to_app_store(
      app_identifier: bundle_id,
      api_key: api_key,
      platform: "osx",
      skip_binary_upload: true, # upload via `make_testflight_release`
      skip_screenshots: options[:skip_screenshots],
      overwrite_screenshots: true,
      screenshots_path: File.join(project_dir, "AppleTVMultiplatformUITests/SnapshotUITests/App-Store/__Snapshots__/AppStoreSnapshotUITests/macOS"),
      skip_metadata: options[:skip_metadata], # /fastlane/metadata
      skip_app_version_update: true,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: true
    )
  end

  desc "Run unit tests on a host macOS machine"
  lane :run_unit_tests do
    sh "cd ..;#{tests_script.call("run-unit-tests-macos.sh")}"
  end

  desc "Run UI Snapshot Tests on a host macOS machine"
  lane :run_ui_snapshots_tests_macos do
    sh "cd ..;#{tests_script.call("run-ui-snapshots-tests-macos.sh")}"
  end

  desc "Re-generate app store snapshots for a host macOS machine"
  lane :make_app_store_snapshots_macos do
    sh "cd ..;#{tests_script.call("make-app-store-snapshots-macos.sh")}"
  end
end
